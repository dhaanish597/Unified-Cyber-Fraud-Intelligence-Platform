# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Neo4j Aura Free (optional). If unset, /graph and /api fall back to an in-memory networkx graph.
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-generated-password

# Kaggle credentials are NOT set here — the kaggle CLI reads ~/.kaggle/kaggle.json directly.
# Do not add a Kaggle token to this file.

# Ledger secret key
LEDGER_SECRET=your-ledger-secret
