# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Runtime mode. Production startup fails closed when required secrets are absent.
FUSION_ENV=production
FUSION_SECURITY_MODE=production
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=fusion-risk-os
JWT_AUDIENCE=fusion-platform
JWT_TTL_SECONDS=900
CORS_ORIGINS=https://dashboard.example.com

# JSON map of client IDs to secrets, roles, and optional tenant/app scopes.
FUSION_AUTH_CLIENTS_JSON={"replace-client":{"secret":"replace-secret","roles":["admin"]}}

# Banking identities. Use password_hash (PBKDF2-SHA256 format) in production
# rather than plaintext password. Plaintext is accepted only as configuration
# input and is immediately converted to a one-way hash in persistent storage.
FUSION_BANK_USERS_JSON=[{"username":"replace-user","password_hash":"pbkdf2_sha256$310000$replace-salt-hex$replace-digest-hex","user_id":"USR_001","display_name":"Banking User","email":"user@example.com","tenant_id":"TENANT_001","app_id":"com.example.bank"}]
BANK_REFRESH_TTL_SECONDS=2592000
DB_PATH=./finspark.db

# Neo4j. If unset, the runtime explicitly reports NETWORKX_FALLBACK.
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-generated-password
GRAPH_FALLBACK_ENABLED=true

# Kaggle credentials are NOT set here — the kaggle CLI reads ~/.kaggle/kaggle.json directly.
# Do not add a Kaggle token to this file.

# 32-byte Ed25519 private key encoded as 64 hexadecimal characters.
LEDGER_SIGNING_KEY=replace-with-64-hex-characters

# Gateway Webhook Secret
GATEWAY_WEBHOOK_SECRET=your-gateway-secret
